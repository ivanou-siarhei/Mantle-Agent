# ---------------------------------------------------------------------------
# Mantle Research Agent — environment configuration
# Copy this file to .env.local and fill in your values. .env.local is
# git-ignored, so your real API key never gets committed.
# ---------------------------------------------------------------------------

# Database (SQLite by default; no setup needed).
DATABASE_URL=file:./db/custom.db

# ---------------------------------------------------------------------------
# Live market data (Lens 1 — pools)
# When unset, live mode is ON by default. Set to "false" to force offline
# sample pools. Real Fluxion pool TVL is pulled from DefiLlama (no key).
# ---------------------------------------------------------------------------
USE_LIVE_DATA=true

# ---------------------------------------------------------------------------
# LLM ("Ask Mantle" + Narrative classify/synthesize)
# Any OpenAI-compatible Chat Completions endpoint works (OpenAI, Groq,
# OpenRouter, Together, local Ollama, ...). With NO key set, the agent
# cleanly falls back to the deterministic MockLLM and still runs.
#
# --- Example: Groq + gpt-oss-120b (free tier) ---
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.groq.com/openai/v1
OPENAI_MODEL=openai/gpt-oss-120b
# Reasoning models (like gpt-oss) burn completion tokens on hidden reasoning.
# "low" keeps the visible answer from being truncated. Omit for non-reasoning
# models (e.g. llama-3.1-8b-instant, gpt-4o-mini).
OPENAI_REASONING_EFFORT=low

# --- Alternative: OpenAI ---
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini
